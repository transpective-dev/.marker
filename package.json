{
  "name": "transpective-marker",
  "displayName": ".Marker",
  "description": "A sticky note for programmers",
  "version": "1.0.0",
  "publisher": "Transpective-Dev-Team",
  "engines": {
    "vscode": "^1.100.0"
  },
  "icon": "./icon.png",
  "repository": "https://github.com/transpective-dev/.marker",
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "marker.addComment",
        "title": ".Marker: Add Comment"
      },
      {
        "command": "marker.highLight",
        "title": "Toggle Marker Highlighting",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "marker.addComment",
          "when": "editorTextFocus",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "command": "marker.highLight",
          "when": "editorTextFocus",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "marker.addComment",
        "key": "ctrl+alt+.",
        "mac": "cmd+alt+.",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "mocha": "12.0.0-beta-10",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.3"
  }
}